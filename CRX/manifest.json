{
  "manifest_version": 3,
  "name": "Duolingo Max + Autolingo",
  "version": "1.0.0",
  "description": "Unlimited hearts, Max features, and auto-completes Duolingo lessons.",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://d35aaqx5ub95lt.cloudfront.net/*",
    "https://*.duolingo.com/*",
    "https://*.duolingo.cn/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://d35aaqx5ub95lt.cloudfront.net/*",
        "https://*.duolingo.cn/*",
        "https://*.duolingo.com/*"
      ],
      "js": [
        "shared/defaults.js",
        "content_script.js",
        "banner.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.duolingo.com/*"
      ],
      "js": [
        "content_scripts/init.js"
      ],
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["<all_urls>"]
    }
  ]
}
